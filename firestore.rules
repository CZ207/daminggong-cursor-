rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string (required) - User's UID
    //   - email: string (required) - User's email
    //   - displayName: string (optional) - User's display name
    //   - photoURL: string (optional) - User's photo URL
    //   - role: string (required) - User's role ('user' or 'admin')
    //   - createdAt: timestamp (required) - Creation time
    //
    // Collection: materials
    // Document ID: materialId
    // Fields:
    //   - id: string (required) - Material ID
    //   - title: string (required) - Material title
    //   - description: string (optional) - Material description
    //   - type: string (required) - Material type ('image', 'video', 'document', '3d_model')
    //   - url: string (required) - Material URL
    //   - thumbnailUrl: string (optional) - Material thumbnail URL
    //   - tags: list (optional) - Material tags
    //   - authorUid: string (required) - Uploader's UID
    //   - createdAt: timestamp (required) - Upload time
    //
    // Collection: userFavorites
    // Document ID: favoriteId
    // Fields:
    //   - userId: string (required) - User's UID
    //   - materialId: string (required) - Material ID
    //   - createdAt: timestamp (required) - Creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "emanhorn2369@gmail.com" && request.auth.token.email_verified == true));
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
        (request.resource.data[field] is string &&
          request.resource.data[field].size() >= minLen &&
          request.resource.data[field].size() <= maxLen);
    }

    function isValidEmail(email) {
      return email is string && email.matches("^[^@]+@[^@]+\\.[^@]+$");
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isValidOptionalUrl(field) {
      return !(field in request.resource.data) || isValidUrl(request.resource.data[field]);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function isValidList(arr, maxSize) {
      return arr is list && arr.size() <= maxSize;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser() {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'role', 'createdAt']) &&
             hasRequiredFields(['uid', 'email', 'role', 'createdAt']) &&
             request.resource.data.uid is string &&
             isValidEmail(request.resource.data.email) &&
             isValidOptionalString('displayName', 1, 100) &&
             isValidOptionalUrl('photoURL') &&
             request.resource.data.role in ['user', 'admin'] &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidMaterial() {
      return hasOnlyAllowedFields(['id', 'title', 'description', 'type', 'url', 'thumbnailUrl', 'tags', 'authorUid', 'createdAt']) &&
             hasRequiredFields(['id', 'title', 'type', 'url', 'authorUid', 'createdAt']) &&
             isValidString('id', 1, 100) &&
             isValidString('title', 1, 200) &&
             isValidOptionalString('description', 0, 5000) &&
             request.resource.data.type in ['image', 'video', 'document', '3d_model'] &&
             isValidUrl(request.resource.data.url) &&
             isValidOptionalUrl('thumbnailUrl') &&
             (!('tags' in request.resource.data) || isValidList(request.resource.data.tags, 20)) &&
             request.resource.data.authorUid is string &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidFavorite() {
      return hasOnlyAllowedFields(['userId', 'materialId', 'createdAt']) &&
             hasRequiredFields(['userId', 'materialId', 'createdAt']) &&
             request.resource.data.userId is string &&
             request.resource.data.materialId is string &&
             request.resource.data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile, but cannot assign themselves 'admin' role unless they are already an admin
      allow create: if isAuthenticated() && 
                    isOwner(userId) && 
                    isValidUser() && 
                    uidUnchanged() &&
                    ((request.resource.data.role == 'user') || isAdmin());
                    
      // Users can update their own profile, but cannot change their role or uid
      allow update: if isAuthenticated() && 
                    isOwner(userId) && 
                    isValidUser() && 
                    uidNotModified() &&
                    areImmutableFieldsUnchanged(['createdAt', 'uid']) &&
                    ((request.resource.data.role == resource.data.role) || isAdmin());
                    
      allow delete: if isAdmin();
    }

    match /materials/{materialId} {
      // Anyone can read materials
      allow read: if isAuthenticated();
      
      // Only admins can create materials
      allow create: if isAdmin() && 
                    isValidMaterial() && 
                    request.resource.data.authorUid == request.auth.uid;
                    
      // Only admins can update materials
      allow update: if isAdmin() && 
                    isValidMaterial() && 
                    areImmutableFieldsUnchanged(['createdAt', 'authorUid', 'id']);
                    
      // Only admins can delete materials
      allow delete: if isAdmin();
    }

    match /userFavorites/{favoriteId} {
      // Users can read their own favorites
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Users can create their own favorites
      allow create: if isAuthenticated() && 
                    isValidFavorite() && 
                    request.resource.data.userId == request.auth.uid;
                    
      // Favorites shouldn't be updated, only deleted and recreated
      allow update: if false;
      
      // Users can delete their own favorites
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
